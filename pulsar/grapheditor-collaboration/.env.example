# GraphEditor Collaboration Server Environment Variables

# Server Configuration
HOST=0.0.0.0
PORT=8001
DEBUG=True

# Room Configuration
ROOM_CLEANUP_DELAY=60
MAX_USERS_PER_ROOM=100

# Environment Configuration
ENVIRONMENT=development  # or production

# Google Cloud Storage Configuration
GCP_PROJECT_ID=your-gcp-project-id
GCP_SERVICE_ACCOUNT_PATH=gcp-service-account.json

# Optional: Override default bucket names
# GCS_BUCKET_DEV=graph-editor
# GCS_BUCKET_PROD=graph-editor-prod

# Logging
LOG_LEVEL=INFO
