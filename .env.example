QAI local development environment template

# =========================================================
# Shared local storage (Orionis + Pulsar + Nebula)
# =========================================================
STORAGE_BACKEND=local

# =========================================================
# Orionis required runtime variables (local)
# =========================================================
ENVIRONMENT=staging

REMOVED=your-gemini-api-key
HMAC_SECRET_KEY_STAGING=replace-with-random-hex
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY_STAGING=your-clerk-publishable-key
CLERK_SECRET_KEY_STAGING=your-clerk-secret-key
CLERK_JWKS_URL_STAGING=https://your-clerk-domain/.well-known/jwks.json
STRIPE_SECRET_KEY_STAGING=your-stripe-secret-key
REMOVED=your-stripe-webhook-secret

NOTIFICATION_WEBHOOK_URL=https://example.invalid/notifications
TEST_RUN_UPDATE_WEBHOOK_URL=https://example.invalid/test-run-updates
CUSTOMER_COMMENTS_WEBHOOK_URL=https://example.invalid/customer-comments
SENTRY_DSN_URL=https://example.invalid/sentry-dsn
TCS_FROM_FLOW_TIMEOUT_MINS=7
JIRA_ENCRYPTION_KEY=replace-with-32-byte-urlsafe-key
ENABLE_SHARDING_FOR_KG_FLOW_ANALYZER=true
ENABLE_NEW_VIDEO_TO_FLOW=true

# Pub/Sub backend: 'redis' (default, local) or 'gcp' (staging/production)
PUBSUB_BACKEND=redis

# Redis configuration (used when PUBSUB_BACKEND=redis)
REDIS_HOST=qai-redis
REDIS_PORT=6379
This file is the single source for local-only variables across:
- orionis
- pulsar/grapheditor-collaboration
- nebula


=========================================================
Shared local storage (Orionis + Pulsar + Nebula)
=========================================================
STORAGE_BACKEND=local
GRAPH_COLLAB_API_URL=http://graph-collab:8001
STORAGE_LOCAL_ROOT=/app/.qai/storage

=========================================================
Orionis required runtime variables (local)
=========================================================
ENVIRONMENT=staging

REMOVED=your-gemini-api-key
HMAC_SECRET_KEY_STAGING=replace-with-random-hex
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY_STAGING=your-clerk-publishable-key
CLERK_SECRET_KEY_STAGING=your-clerk-secret-key
CLERK_JWKS_URL_STAGING=https://your-clerk-domain/.well-known/jwks.json
STRIPE_SECRET_KEY_STAGING=your-stripe-secret-key
REMOVED=your-stripe-webhook-secret

NOTIFICATION_WEBHOOK_URL=https://example.invalid/notifications
TEST_RUN_UPDATE_WEBHOOK_URL=https://example.invalid/test-run-updates
CUSTOMER_COMMENTS_WEBHOOK_URL=https://example.invalid/customer-comments
SENTRY_DSN_URL=https://example.invalid/sentry-dsn
TCS_FROM_FLOW_TIMEOUT_MINS=7
JIRA_ENCRYPTION_KEY=replace-with-32-byte-urlsafe-key
ENABLE_SHARDING_FOR_KG_FLOW_ANALYZER=true
ENABLE_NEW_VIDEO_TO_FLOW=true

=========================================================
Pulsar graph collaboration required runtime variables (local)
=========================================================
HOST=0.0.0.0
PORT=8001
DEBUG=True
GCS_TIMEOUT_SECONDS=15

=========================================================
Nebula required runtime variables (local)
=========================================================
NEXT_PUBLIC_APP_ENV=development
NEXT_PUBLIC_ORIONIS_URL=http://orionis:8080
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=your-clerk-publishable-key
CLERK_SECRET_KEY=your-clerk-secret-key
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=your-stripe-publishable-key

NEXT_PUBLIC_CLERK_SIGN_IN_FORCE_REDIRECT_URL=/dashboard
NEXT_PUBLIC_CLERK_SIGN_UP_FORCE_REDIRECT_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

NEXT_PUBLIC_SENTRY_PROJECT=nebula
NEXT_PUBLIC_SENTRY_DSN=https://example.invalid/nebula-sentry-dsn
